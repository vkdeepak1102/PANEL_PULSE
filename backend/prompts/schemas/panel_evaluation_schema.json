{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PanelEvaluation",
  "type": "object",
  "required": ["job_id","score","categories","evidence","probing_verdict","l2_validation"],
  "properties": {
    "job_id": { "type": "string" },
    "score": { "type": "number", "minimum": 0, "maximum": 10 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "categories": {
      "type": "object",
      "properties": {
        "Mandatory Skill Coverage": { "type": "number" },
        "Technical Depth": { "type": "number" },
        "Scenario / Risk Evaluation": { "type": "number" },
        "Framework Knowledge": { "type": "number" },
        "Hands-on Validation": { "type": "number" },
        "Leadership Evaluation": { "type": "number" },
        "Behavioral Assessment": { "type": "number" },
        "Rejection Validation Alignment": { "type": "number" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["quote","source"],
        "properties": {
          "quote": { "type": "string" },
          "source": { "type": "string" },
          "timestamp": { "type": "string" }
        }
      }
    },
    "probing_verdict": { "type": "string", "enum": ["NO_PROBING","SURFACE_PROBING","DEEP_PROBING"] },
    "l2_validation": {
      "type": "object",
      "required": ["matches_evidence","notes"],
      "properties": {
        "matches_evidence": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
