## Backend Server Configuration

# Listen port
PORT=3000

# NODE_ENV: set to 'production' in production deployments
NODE_ENV=production

# MongoDB Connection (Atlas) - replace with your production connection string
MONGODB_URI=mongodb://<username>:<password>@cluster.mongodb.net:27017/dbname?authSource=admin&replicaSet=replicaset&ssl=true
MONGODB_DB=panel_db

# Frontend URL (for CORS)
FRONTEND_URL=https://panel-pulse.vercel.app

# API Keys (set these in the deployment platform - never commit real keys)
MISTRAL_API_KEY=<your_mistral_api_key>
GROQ_API_KEY=<your_groq_api_key>

# Optional: Custom Port for API
# API_PORT=3000

# Development example (uncomment if running locally):
# NODE_ENV=development
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/?retryWrites=true&w=majority
# MONGODB_DB=pp_db
